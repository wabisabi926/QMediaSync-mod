{
  "name": "qmediasync",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22.22.2",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm run type-check && pnpm run build-only",
    "lint": "eslint \"./{src,test}/**/*.{js,jsx,mjs,ts,tsx,vue}\"",
    "lint:fix": "eslint \"./{src,test}/**/*.{js,jsx,mjs,ts,tsx,vue}\" --fix",
    "build-only": "vite build --mode=production --emptyOutDir --outDir dist",
    "check:build": "node test/regression/charts-chunk-cycle.check.mjs",
    "dev": "vite",
    "format": "prettier --write src/ test/",
    "format:check": "prettier --check src/ test/",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.18.1",
    "dompurify": "^3.4.12",
    "echarts": "^6.0.0",
    "element-plus": "^2.14.3",
    "github-markdown-css": "^5.8.1",
    "markdown-it": "^14.3.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.40",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.20.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.5",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7"
  },
  "type": "module"
}

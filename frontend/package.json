{
  "name": "q115-strm",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm run type-check && pnpm run build-only",
    "lint": "eslint \"./src/**/*.{js,jsx,ts,tsx,vue}\"",
    "lint:fix": "eslint \"./src/**/*.{js,jsx,ts,tsx,vue}\" --fix",
    "build-only": "vite build --mode=production --emptyOutDir --outDir ../backend/web_statics",
    "dev": "vite",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "preview": "vite preview",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.18.0",
    "dompurify": "^3.4.11",
    "echarts": "^6.0.0",
    "element-plus": "^2.14.2",
    "github-markdown-css": "^5.8.1",
    "markdown-it": "^14.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.20.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0",
    "vite": "^6.4.1",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "type": "module"
}

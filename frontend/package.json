{
  "name": "qmediasync",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm run type-check && pnpm run build-only",
    "lint": "eslint \"./src/**/*.{js,jsx,ts,tsx,vue}\"",
    "lint:fix": "eslint \"./src/**/*.{js,jsx,ts,tsx,vue}\" --fix",
    "build-only": "vite build --mode=production --emptyOutDir --outDir ../backend/web_statics",
    "dev": "vite",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "preview": "vite preview",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.18.0",
    "dompurify": "^3.4.11",
    "echarts": "^6.0.0",
    "element-plus": "^2.14.2",
    "github-markdown-css": "^5.8.1",
    "markdown-it": "^14.2.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.38",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.20.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "type": "module"
}
